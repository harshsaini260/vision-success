// ════════════════════════════════════════════════════════════════
// VISION SUCCESS — Firestore Security Rules
// Paste this in: Firebase Console → Firestore Database → Rules → Publish
//
// These rules match exactly how the website queries data:
//  • Public pages read ONLY published materials / approved reviews
//  • Anyone can submit appointments, enrollments, and reviews
//  • Admin panel needs a Firebase Auth login (README → "Admin Setup")
// ════════════════════════════════════════════════════════════════
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ONLY the owner's account counts as admin — even if someone
    // manages to create another Auth user, they get nothing.
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'harshsaini0502@gmail.com';
    }

    // ── Counseling bookings (from /appointment) ──
    match /appointments/{docId} {
      allow create: if true;                       // public form
      allow read, update, delete: if isAdmin();    // admin panel only
    }

    // ── Admission requests (from /enroll) ──
    match /enrollments/{docId} {
      allow create: if true;                       // public form
      allow read, update, delete: if isAdmin();
    }

    // ── Student reviews (from /reviews) ──
    match /reviews/{docId} {
      // New reviews must arrive unapproved; admin flips the switch
      allow create: if request.resource.data.approved == false;
      allow read: if resource.data.approved == true || isAdmin();
      allow update, delete: if isAdmin();
    }

    // ── Study materials (shown on /materials) ──
    match /materials/{docId} {
      allow read: if resource.data.published == true || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // ── SAT Predictor leads (from the homepage predictor tool) ──
    match /predictions/{docId} {
      allow create: if true;                       // public tool
      allow read, update, delete: if isAdmin();
    }

    // ── Survey responses (from the /start QR survey) ──
    match /surveys/{docId} {
      allow create: if true;                       // public survey
      allow read, update, delete: if isAdmin();
    }

    // Everything else: locked.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

// ────────────────────────────────────────────────────────────────
